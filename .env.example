# ============================================================================
# VOTING SYSTEM ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit the .env file to version control!

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Secret key for session management and CSRF protection
# Generate a secure key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-random-key-here-make-it-at-least-32-characters-long

# Flask environment (development or production)
FLASK_ENV=development

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite database location (default)
DATABASE_URL=sqlite:///instance/voting_system.db

# For PostgreSQL (production):
# DATABASE_URL=postgresql://username:password@localhost/voting_system

# For MySQL (production):
# DATABASE_URL=mysql://username:password@localhost/voting_system

# ============================================================================
# EMAIL CONFIGURATION (for OTP)
# ============================================================================

# Gmail Configuration (Recommended for development)
# Steps to setup Gmail:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to: Google Account → Security → 2-Step Verification → App Passwords
# 3. Generate an "App Password" for Mail
# 4. Use your Gmail address and the generated app password below

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_DEFAULT_SENDER=your-email@gmail.com

# Alternative: Outlook/Hotmail Configuration
# MAIL_SERVER=smtp-mail.outlook.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USE_SSL=False
# MAIL_USERNAME=your-email@outlook.com
# MAIL_PASSWORD=your-password
# MAIL_DEFAULT_SENDER=your-email@outlook.com

# Alternative: Custom SMTP Server
# MAIL_SERVER=smtp.yourserver.com
# MAIL_PORT=587
# MAIL_USE_TLS=True
# MAIL_USE_SSL=False
# MAIL_USERNAME=your-email@yourserver.com
# MAIL_PASSWORD=your-password
# MAIL_DEFAULT_SENDER=your-email@yourserver.com

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# GPS Encryption Key (for encrypting GPS coordinates in audit logs)
# Generate a new key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GPS_ENCRYPTION_KEY=your-gps-encryption-key-here

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. Generate a strong SECRET_KEY using the command above
# 2. For Gmail, use App Password, NOT your regular password
# 3. Enable 2FA on Gmail before creating App Password
# 4. Never commit .env file to version control
# 5. Change default admin password after first login
# 6. Use HTTPS in production
# 7. Regularly backup your database
# ============================================================================